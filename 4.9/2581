a = int(input())
b = int(input())

s = 0
m = 0

for i in range(a, b + 1):
    if i == 1:
        continue

    p = True

    for j in range(2, i):
        if i % j == 0:
            p = False
            break

    if p:
        s += i
        if m == 0:
            m = i

if s == 0:
    print(-1)
else:
    print(s)
    print(m)